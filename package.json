{
    "name": "@slopus/rig-workspace",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "pnpm --filter @slopus/rig build",
        "build:gym": "docker build --file packages/gym/Dockerfile --tag rig-gym:local .",
        "build:web": "pnpm --filter @slopus/rig-web build",
        "check": "pnpm run check:root && pnpm --recursive --filter './packages/**' run check && pnpm --filter @slopus/rig-gym-tests check",
        "check:root": "tsc --noEmit -p tsconfig.json",
        "check:web": "pnpm --filter @slopus/rig-web check",
        "dev": "tsx packages/rig/sources/main.ts",
        "dev:web": "pnpm --filter @slopus/rig-web dev",
        "format": "oxfmt --write .",
        "format:check": "oxfmt --check .",
        "lint": "oxlint .",
        "release": "tsx scripts/release.ts",
        "start": "node packages/rig/dist/main.js",
        "start:build": "pnpm build && pnpm start",
        "test": "pnpm --recursive --filter './packages/**' run test",
        "test:gym": "pnpm build:gym && RIG_GYM_SKIP_BUILD=1 pnpm --filter @slopus/rig-gym-tests test",
        "test:live": "pnpm --filter @slopus/rig test:live",
        "test:watch": "pnpm --filter @slopus/rig test:watch",
        "web": "node packages/rig/dist/main.js web"
    },
    "devDependencies": {
        "@types/node": "^24.0.10",
        "oxfmt": "^0.57.0",
        "oxlint": "^1.72.0",
        "tsx": "^4.23.0",
        "typescript": "^5.8.3"
    },
    "packageManager": "pnpm@10.28.1"
}
