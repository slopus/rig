{
  "name": "ohmypi",
  "version": "0.0.0",
  "description": "Opinionated pi fork with strong defaults for coding-agent workflows.",
  "type": "module",
  "packageManager": "pnpm@10.28.1",
  "bin": {
    "ohmypi": "./dist/main.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:live": "OHMYPI_LIVE_TEST=1 vitest run -c vitest.live.config.ts",
    "test:watch": "vitest"
  },
  "keywords": [
    "pi",
    "coding-agent",
    "agent-harness"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^24.0.10",
    "typescript": "^5.8.3",
    "vite": "^7.0.2",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@mariozechner/pi-ai": "^0.73.1",
    "@sinclair/typebox": "^0.34.49"
  }
}
