{
    "name": "@slopus/rig",
    "version": "0.0.2",
    "description": "Opinionated pi fork with strong defaults for coding-agent workflows.",
    "keywords": [
        "agent-harness",
        "coding-agent",
        "pi"
    ],
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/slopus/rig.git"
    },
    "bin": {
        "rig": "./dist/main.js"
    },
    "files": [
        "dist"
    ],
    "type": "module",
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build": "tsc -p tsconfig.build.json && pnpm run build:web",
        "build:web": "vite build --config web_sources/vite.config.ts",
        "check": "tsc --noEmit && pnpm run check:web",
        "check:web": "tsc -p web_sources/tsconfig.json --noEmit",
        "dev": "tsx sources/main.ts",
        "dev:web": "vite --config web_sources/vite.config.ts --host 127.0.0.1",
        "format": "oxfmt --write .",
        "format:check": "oxfmt --check .",
        "lint": "oxlint .",
        "release": "tsx scripts/release.ts",
        "start": "node dist/main.js",
        "start:build": "pnpm build && node dist/main.js",
        "test": "vitest run",
        "test:live": "RIG_LIVE_TEST=1 vitest run -c vitest.live.config.ts",
        "test:watch": "vitest",
        "web": "node dist/main.js web"
    },
    "dependencies": {
        "@anthropic-ai/claude-agent-sdk": "^0.3.201",
        "@anthropic-ai/sdk": "^0.110.0",
        "@earendil-works/pi-tui": "^0.80.3",
        "@ff-labs/fff-node": "^0.9.6",
        "@mariozechner/clipboard": "^0.3.9",
        "@mariozechner/pi-ai": "^0.73.1",
        "@modelcontextprotocol/sdk": "^1.29.0",
        "@paralleldrive/cuid2": "^3.3.0",
        "@sinclair/typebox": "^0.34.49",
        "lru-cache": "^11.5.2",
        "openai": "6.46.0",
        "portless": "^0.15.1",
        "sharp": "^0.35.3",
        "smol-toml": "^1.7.0",
        "turndown": "^7.2.4",
        "yaml": "^2.9.0",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@radix-ui/react-use-controllable-state": "^1.2.3",
        "@tailwindcss/vite": "^4.3.2",
        "@types/node": "^24.0.10",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "@types/turndown": "^5.0.6",
        "@vitejs/plugin-react": "^5.2.0",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "just-bash": "^3.0.2",
        "lucide-react": "^1.23.0",
        "oxfmt": "^0.57.0",
        "oxlint": "^1.72.0",
        "radix-ui": "^1.6.1",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "shiki": "^4.3.1",
        "streamdown": "^2.5.0",
        "tailwind-merge": "^3.6.0",
        "tailwindcss": "^4.3.2",
        "tsx": "^4.23.0",
        "tw-animate-css": "^1.4.0",
        "typescript": "^5.8.3",
        "use-stick-to-bottom": "^1.1.6",
        "vite": "^7.0.2",
        "vitest": "^3.2.4"
    },
    "optionalDependencies": {
        "@anthropic-ai/claude-agent-sdk-darwin-arm64": "^0.3.201",
        "@anthropic-ai/claude-agent-sdk-darwin-x64": "^0.3.201",
        "@anthropic-ai/claude-agent-sdk-linux-arm64": "^0.3.201",
        "@anthropic-ai/claude-agent-sdk-linux-arm64-musl": "^0.3.201",
        "@anthropic-ai/claude-agent-sdk-linux-x64": "^0.3.201",
        "@anthropic-ai/claude-agent-sdk-linux-x64-musl": "^0.3.201",
        "@anthropic-ai/claude-agent-sdk-win32-arm64": "^0.3.201",
        "@anthropic-ai/claude-agent-sdk-win32-x64": "^0.3.201"
    },
    "packageManager": "pnpm@10.28.1"
}
