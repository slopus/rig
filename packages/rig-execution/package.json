{
    "name": "@slopus/rig-execution",
    "version": "0.0.0",
    "description": "Stable execution core for Rig coding models.",
    "license": "MIT",
    "files": [
        "dist",
        "README.md"
    ],
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        }
    },
    "scripts": {
        "build": "node --eval \"import('node:fs/promises').then(({ rm }) => rm('dist', { force: true, recursive: true }))\" && tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
        "check": "tsc --noEmit",
        "test": "vitest run"
    },
    "dependencies": {
        "@sinclair/typebox": "^0.34.49",
        "@slopus/rig-providers": "workspace:*"
    },
    "devDependencies": {
        "@types/node": "^24.0.10",
        "tsc-alias": "^1.8.16",
        "typescript": "^7.0.2",
        "vitest": "^3.2.4"
    },
    "engines": {
        "node": ">=20"
    }
}
