{
    "name": "@slopus/rig-providers",
    "version": "0.0.0",
    "description": "Provider abstractions for Rig.",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/slopus/rig.git",
        "directory": "packages/rig-providers"
    },
    "files": [
        "dist",
        "LICENSE",
        "README.md"
    ],
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        }
    },
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build": "node --eval \"import('node:fs/promises').then(({ rm }) => rm('dist', { force: true, recursive: true }))\" && tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
        "check": "tsc --noEmit",
        "test": "vitest run --passWithNoTests"
    },
    "devDependencies": {
        "@types/node": "^24.0.10",
        "tsc-alias": "^1.8.16",
        "typescript": "^7.0.2",
        "vitest": "^3.2.4"
    },
    "engines": {
        "node": ">=20"
    },
    "dependencies": {
        "@anthropic-ai/claude-agent-sdk": "^0.3.201",
        "@modelcontextprotocol/sdk": "^1.29.0",
        "@sinclair/typebox": "^0.34.49",
        "openai": "6.46.0",
        "undici": "^8.8.0"
    }
}
