{
    "name": "@slopus/rig",
    "version": "0.0.44",
    "description": "Opinionated coding-agent harness with strong defaults for provider-aligned workflows.",
    "keywords": [
        "agent-harness",
        "coding-agent",
        "pi"
    ],
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/slopus/rig.git"
    },
    "bin": {
        "rig": "./dist/main.js"
    },
    "files": [
        "dist",
        "LICENSE-CODEX",
        "LICENSE-HAPPY",
        "LICENSE-GROK-BUILD",
        "THIRD-PARTY-NOTICES.md"
    ],
    "type": "module",
    "exports": {
        "./types": {
            "types": "./dist/types.d.ts"
        },
        "./package-version": {
            "types": "./dist/readPackageVersion.d.ts",
            "import": "./dist/readPackageVersion.js",
            "default": "./dist/readPackageVersion.js"
        },
        "./dist/main.js": "./dist/main.js",
        "./dist/readPackageVersion.js": {
            "types": "./dist/readPackageVersion.d.ts",
            "import": "./dist/readPackageVersion.js",
            "default": "./dist/readPackageVersion.js"
        },
        "./dist/protocol/index.js": {
            "types": "./dist/types.d.ts"
        },
        "./dist/terminal/index.js": {
            "types": "./dist/types.d.ts"
        },
        "./dist/external-tools/index.js": {
            "types": "./dist/types.d.ts"
        }
    },
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build": "tsx scripts/build.ts",
        "check": "tsc --noEmit",
        "dev": "pnpm --filter @slopus/rig-dev dev",
        "start": "node dist/main.js",
        "test": "vitest run --isolate=false",
        "test:live": "RIG_LIVE_TEST=1 vitest run -c vitest.live.config.ts",
        "test:watch": "vitest"
    },
    "dependencies": {
        "@anthropic-ai/claude-agent-sdk": "^0.3.201",
        "@anthropic-ai/sandbox-runtime": "^0.0.64",
        "@anthropic-ai/sdk": "^0.110.0",
        "@ff-labs/fff-node": "^0.9.6",
        "@lydell/node-pty": "1.2.0-beta.12",
        "@mariozechner/clipboard": "^0.3.9",
        "@modelcontextprotocol/sdk": "^1.29.0",
        "@pydantic/monty": "0.0.18",
        "@slopus/ghostty-wasm": "1.3.4",
        "@vscode/ripgrep": "1.18.0",
        "sharp": "^0.35.3",
        "ssh2": "^1.17.0",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@earendil-works/pi-tui": "^0.80.3",
        "@paralleldrive/cuid2": "^3.3.0",
        "@sinclair/typebox": "^0.34.49",
        "@slopus/ghostty-web": "workspace:*",
        "@slopus/rig-execution": "workspace:*",
        "@slopus/rig-providers": "workspace:*",
        "@types/dockerode": "^4.0.1",
        "@types/node": "^24.0.10",
        "@types/proper-lockfile": "^4.1.4",
        "@types/qrcode": "^1.5.6",
        "@types/qrcode-terminal": "^0.12.2",
        "@types/tar-stream": "^3.1.4",
        "@types/turndown": "^5.0.6",
        "@types/ws": "^8.18.1",
        "deunicode": "1.0.7",
        "dockerode": "^5.0.1",
        "esbuild": "^0.28.1",
        "ignore": "^7.0.6",
        "just-bash": "^3.0.2",
        "lru-cache": "^11.5.2",
        "openai": "6.46.0",
        "proper-lockfile": "^4.1.2",
        "qrcode": "^1.5.4",
        "qrcode-terminal": "^0.12.0",
        "smol-toml": "^1.7.0",
        "socket.io-client": "^4.8.1",
        "tar-stream": "^3.2.0",
        "tsx": "^4.23.0",
        "turndown": "^7.2.4",
        "tweetnacl": "^1.0.3",
        "typescript": "^5.8.3",
        "vitest": "^3.2.4",
        "wink-porter2-stemmer": "2.0.1",
        "ws": "^8.21.1",
        "yaml": "^2.9.0"
    },
    "optionalDependencies": {
        "@anthropic-ai/claude-agent-sdk-darwin-arm64": "^0.3.201",
        "@anthropic-ai/claude-agent-sdk-darwin-x64": "^0.3.201",
        "@anthropic-ai/claude-agent-sdk-linux-arm64": "^0.3.201",
        "@anthropic-ai/claude-agent-sdk-linux-arm64-musl": "^0.3.201",
        "@anthropic-ai/claude-agent-sdk-linux-x64": "^0.3.201",
        "@anthropic-ai/claude-agent-sdk-linux-x64-musl": "^0.3.201",
        "@anthropic-ai/claude-agent-sdk-win32-arm64": "^0.3.201",
        "@anthropic-ai/claude-agent-sdk-win32-x64": "^0.3.201",
        "@mongodb-js/zstd": "^7.0.0",
        "node-liblzma": "^2.0.3"
    }
}
