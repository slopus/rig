{
    "name": "@slopus/rig-gym-tests",
    "private": true,
    "type": "module",
    "scripts": {
        "check": "tsc --noEmit",
        "prepare:image": "pnpm --filter @slopus/rig-gym run build:image",
        "test:gym": "pnpm run test:gym:fast",
        "test:gym:just-bash": "node runGymLane.ts local",
        "test:gym:fast": "node runGymLane.ts fast",
        "test:gym:heavy": "pnpm run prepare:image && RIG_GYM_SKIP_BUILD=1 node runGymLane.ts heavy",
        "test:gym:slow": "node runGymLane.ts slow",
        "test:gym:full": "pnpm run test:gym:fast && pnpm run test:gym:slow && pnpm run test:gym:docker",
        "test:gym:docker": "pnpm run prepare:image && RIG_GYM_SKIP_BUILD=1 node runGymLane.ts docker"
    },
    "dependencies": {
        "@openai/codex": "0.145.0"
    },
    "devDependencies": {
        "@earendil-works/pi-tui": "^0.80.3",
        "@slopus/rig-gym": "workspace:*",
        "@slopus/rig-providers": "workspace:*",
        "@slopus/rig-execution": "workspace:*",
        "@types/node": "^24.0.10",
        "typescript": "^5.8.3",
        "vitest": "^3.2.4"
    }
}
